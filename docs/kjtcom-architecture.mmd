%% kjtcom Architecture - Living Document
%% Updated: v9.49 - Schema-Validated Qwen Harness + MW Tab + Execution Order Fix
%% Maintainer: Update every iteration that changes architecture

graph TB
    subgraph USER["User Layer"]
        WEB["kylejeromethompson.com<br/>Flutter Web"]
        TELEGRAM["Telegram Bot<br/>@kjtcom_iao_bot<br/>systemd managed"]
        CLAW3D["Claw3D Viewer<br/>Three.js Prototype"]
        SYSTEMD_SVC["systemd Service<br/>WatchdogSec=600<br/>Auto-restart"]
    end

    subgraph FRONTEND["Flutter Web App (6 tabs)"]
        RESULTS["Results Tab"]
        MAP["Map Tab<br/>OpenStreetMap"]
        GLOBE["Globe Tab<br/>Stats Dashboard"]
        IAO_TAB["IAO Tab<br/>Methodology"]
        MW_TAB["MW Tab<br/>Middleware Showcase"]
        SCHEMA_TAB["Schema Tab<br/>22 t_any_* Fields"]
    end

    subgraph QUERY["Query Engine"]
        EDITOR["NoSQL Query Editor<br/>Syntax Highlighting"]
        PARSER["QueryClause Parser<br/>Tokenizer + Validation"]
        AUTOCOMPLETE["Inline Autocomplete<br/>21 fields, 6878 values"]
    end

    subgraph FIREBASE["Firebase (kjtcom-c78cd)"]
        FIRESTORE["Cloud Firestore<br/>6,181 entities"]
        FUNCTIONS["Cloud Functions<br/>Search API"]
        HOSTING["Firebase Hosting<br/>CDN + SSL"]
        STAGING["Staging DB"]
        PRODUCTION["Production DB (default)"]
    end

    subgraph PIPELINES["3 Live Pipelines"]
        CALGOLD["CalGold<br/>899 entities"]
        RICKSTEVES["RickSteves<br/>4,182 entities"]
        TRIPLEDB["TripleDB<br/>1,100 entities"]
    end

    subgraph PIPELINE_STAGES["Pipeline Processing"]
        P1["Phase 1: Acquire<br/>yt-dlp"]
        P2["Phase 2: Transcribe<br/>faster-whisper CUDA"]
        P3["Phase 3: Extract<br/>Gemini 2.5 Flash API"]
        P4["Phase 4: Normalize<br/>Thompson Schema"]
        P5["Phase 5: Geocode<br/>Nominatim"]
        P6["Phase 6: Enrich<br/>Google Places API"]
        P7["Phase 7: Load<br/>Firebase Admin SDK"]
        P1 --> P2 --> P3 --> P4 --> P5 --> P6 --> P7
    end

    subgraph AGENTS["Agent Orchestration (IAO)"]
        CLAUDE["Claude Code<br/>Opus 4.6"]
        GEMINI_CLI["Gemini CLI<br/>Primary Executor (v9.47)"]
        TMUX["tmux Runner<br/>Unattended Pipelines"]
    end

    subgraph LOCAL_LLMS["Local LLMs (Ollama)"]
        QWEN["Qwen3.5-9B<br/>Permanent Evaluator<br/>~5.1 GB VRAM"]
        NEMOTRON["Nemotron Mini 4B<br/>Fast Triage<br/>~2.7 GB VRAM"]
        GLM["GLM-4.6V-Flash-9B<br/>Vision<br/>~4.8 GB VRAM"]
        NOMIC["nomic-embed-text<br/>Embedding Only<br/>~270 MB VRAM"]
    end

    subgraph MCP["MCP Servers (5)"]
        MCP_FIREBASE["Firebase MCP<br/>Firestore Queries"]
        MCP_CONTEXT7["Context7 MCP<br/>API Docs"]
        MCP_FIRECRAWL["Firecrawl MCP<br/>Web Scraping"]
        MCP_PLAYWRIGHT["Playwright MCP<br/>Browser Automation"]
        MCP_DART["Dart MCP<br/>Code Analysis"]
    end

    subgraph MIDDLEWARE["Middleware (v9.49+)"]
        RAG["RAG Pipeline<br/>ChromaDB + nomic-embed"]
        CHROMADB["ChromaDB<br/>data/chromadb/<br/>1,590 chunks"]
        EVAL_SCHEMA["Eval Schema<br/>data/eval_schema.json<br/>Strict JSON Schema"]
        EVALUATOR["Agent Evaluator<br/>Qwen3.5-9B Scorer<br/>Schema-Validated v9.49"]
        REGISTRY["iteration_registry.json<br/>47 iterations"]
        SCORES["agent_scores.json<br/>Token Tracking"]
        LEADERBOARD["Leaderboard Generator"]
        BRAVE["Brave Search API<br/>Web Research"]
        OPENCLAW["OpenClaw<br/>open-interpreter 0.4.3<br/>Gemini Flash Engine"]
        EVENT_LOG["Event Log<br/>data/iao_event_log.jsonl<br/>P3 Diligence"]
        ANALYZER["analyze_events.py<br/>Event Log Summary"]
        SCHEMA_REF["Schema Reference<br/>data/schema_reference.json<br/>22 Fields + 3 Pipelines"]
        INTENT_ROUTER["Intent Router<br/>Gemini Flash<br/>3 Routes: Firestore/ChromaDB/Web"]
        ARTIFACT_GEN["Artifact Generator<br/>generate_artifacts.py<br/>--promote --validate-only"]
        GOTCHA_ARCHIVE["Gotcha Archive<br/>data/gotcha_archive.json<br/>18 Resolved Patterns"]
        HARNESS_REGISTRY["Middleware Registry<br/>data/middleware_registry.json<br/>Component Catalog"]
        COUNTY_ENRICHMENT["County Enrichment<br/>enrich_counties.py<br/>Nominatim Reverse Geocode"]
        POST_FLIGHT["Post-Flight Verification<br/>post_flight.py<br/>Site + Bot + Query Checks"]
        SESSION_MEM["Bot Session Memory<br/>user_sessions dict<br/>10-min TTL"]
        ARCH_HTML["Architecture HTML<br/>build_architecture_html.py<br/>Mermaid JS Renderer"]
    end

    subgraph ARTIFACTS["Artifact Loop (per iteration)"]
        DESIGN["Design Doc"]
        PLAN["Plan Doc"]
        BUILD["Build Log"]
        REPORT["Report + Scorecard"]
        CHANGELOG["Changelog"]
        ARCH_MMD["architecture.mmd<br/>(this file)"]
    end

