    FRONTEND --> QUERY
    QUERY --> FIREBASE
    FIRESTORE --> FUNCTIONS
    HOSTING --> WEB

    %% Pipeline connections
    PIPELINES --> PIPELINE_STAGES
    P7 --> FIRESTORE

    %% Agent connections
    CLAUDE --> MCP
    CLAUDE --> LOCAL_LLMS
    CLAUDE --> MIDDLEWARE
    GEMINI_CLI --> PIPELINE_STAGES
    TMUX --> PIPELINE_STAGES

    %% Middleware connections
    RAG --> CHROMADB
    RAG --> NOMIC
    EVALUATOR --> QWEN
    EVALUATOR --> SCORES
    EVAL_SCHEMA --> EVALUATOR
    LEADERBOARD --> SCORES
    REGISTRY --> RAG
    OPENCLAW --> LOCAL_LLMS
    EVENT_LOG --> ANALYZER
    ANALYZER --> REPORT
    INTENT_ROUTER --> SCHEMA_REF
    INTENT_ROUTER --> EVENT_LOG
    ARTIFACT_GEN --> EVENT_LOG
    ARTIFACT_GEN --> SCORES
    ARTIFACT_GEN --> BUILD
    ARTIFACT_GEN --> REPORT
    EVALUATOR --> EVENT_LOG
    BRAVE --> EVENT_LOG
    COUNTY_ENRICHMENT --> FIRESTORE
    COUNTY_ENRICHMENT --> EVENT_LOG
    GOTCHA_ARCHIVE --> EVALUATOR
    HARNESS_REGISTRY --> ARTIFACT_GEN
    POST_FLIGHT --> EVENT_LOG
    SESSION_MEM --> TELEGRAM
    ARCH_HTML --> HOSTING

    %% MCP connections
    MCP_FIREBASE --> FIRESTORE
    MCP_DART --> FRONTEND

    %% Artifact connections
    EVALUATOR --> REPORT
    DESIGN --> PLAN --> BUILD --> REPORT

